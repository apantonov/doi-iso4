@article{OtsuboCommu2022,
	abstract = {The rate of entropy production provides a useful quantitative measure of a non-equilibrium system and estimating it directly from time-series data from experiments is highly desirable. Several approaches have been considered for stationary dynamics, some of which are based on a variational characterization of the entropy production rate. However, the issue of obtaining it in the case of non-stationary dynamics remains largely unexplored. Here, we solve this open problem by demonstrating that the variational approaches can be generalized to give the exact value of the entropy production rate even for non-stationary dynamics. On the basis of this result, we develop an efficient algorithm that estimates the entropy production rate continuously in time by using machine learning techniques and validate our numerical estimates using analytically tractable Langevin models in experimentally relevant parameter regimes. Our method only requires time-series data for the system of interest without any prior knowledge of the system's parameters.},
	author = {Otsubo, Shun and Manikandan, Sreekanth K. and Sagawa, Takahiro and Krishnamurthy, Supriya},
	date = {2022/01/10},
	date-added = {2023-08-30 17:18:01 +0900},
	date-modified = {2023-08-30 17:18:01 +0900},
	doi = {10.1038/s42005-021-00787-x},
	id = {Otsubo2022},
	isbn = {2399-3650},
	journal = {Commun. Phys.},
	number = {1},
	pages = {11},
	title = {Estimating time-dependent entropy production from non-equilibrium trajectories},
	url = {https://doi.org/10.1038/s42005-021-00787-x},
	volume = {5},
	year = {2022},
	bdsk-url-1 = {https://doi.org/10.1038/s42005-021-00787-x}}

